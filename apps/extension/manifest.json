{
  "manifest_version": 3,
  "name": "Vivy Browser Ingestor",
  "version": "0.1.0",
  "description": "Logs videos watched, searches, and time per site to my Vivy Event API. Personal use.",
  "permissions": ["tabs", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["yt-meta.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
